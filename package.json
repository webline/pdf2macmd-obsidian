{
  "name": "pdf2macmd-obsidian",
  "version": "0.1.0",
  "description": "Obsidian-Plugin-Frontend für das pdf2macmd-Binary (PDF → Markdown via Apple Vision, on-device).",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "pdf",
    "markdown",
    "ocr",
    "vision"
  ],
  "author": "Detlef Beyer / Medienkonzepte GbR",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.3.0"
  }
}
